# ── Waitlist capture ─────────────────────────────────────────────
# Endpoint the <Waitlist /> form POSTs to via /api/waitlist.
# DEFAULT (when unset): the shared LandlordReady Google Sheet — TradeComply rows
# are tagged `tradecomply:` in the source column. Only set this to override with
# a different Apps Script / form endpoint if you split sheets later.
WAITLIST_WEBHOOK_URL=

# ── Analytics (privacy-light) ────────────────────────────────────
# GA4 measurement id. Leave blank to disable analytics entirely.
NEXT_PUBLIC_GA_ID=

# ── Search Console ───────────────────────────────────────────────
# Google Search Console HTML-tag verification token (the content="" value).
# Needed once to verify tradecomply.co.uk so the gtm-agents seo-monitor
# agent can read GSC metrics. Leave blank until you verify the property.
NEXT_PUBLIC_GSC_VERIFICATION=
